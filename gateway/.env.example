PORT=8080
ANTHROPIC_UPSTREAM=https://api.anthropic.com

# --- Phase 2: Postgres request-log persistence ---
# These three feed docker-compose.yml (the local dev Postgres).
POSTGRES_USER=slice
POSTGRES_PASSWORD=slice
POSTGRES_DB=slice

# Connection string the gateway (src/db.ts) uses. Must match the vars above.
DATABASE_URL=postgres://slice:slice@localhost:5432/slice

# --- Phase 3: classifier-based router ---
# Master switch. Default false = pure pass-through (identical to Phase 2).
ROUTER_ENABLED=false
# Cheap model used for the EASY/HARD judge call.
JUDGE_MODEL=claude-haiku-4-5-20251001
# Tier mapping: EASY -> cheap, HARD -> strong. Each can be a COMMA-SEPARATED list
# of models in the tier (Phase 6). A single value behaves exactly like before; with
# several, the cost ranking picks the cheapest known model within the chosen tier,
# falling back to the first entry when the ranking has no data.
ROUTER_CHEAP_MODEL=claude-haiku-4-5-20251001
ROUTER_STRONG_MODEL=claude-opus-4-8
# Judge call timeout (ms) and in-memory verdict-cache size (optional).
JUDGE_TIMEOUT_MS=4000
ROUTER_CACHE_MAX=1000
# Note: the judge reuses the CLIENT's API key from each request — no key here.

# --- Phase 4: Redis-backed response cache + budget caps ---
# Redis connection (feeds docker-compose.yml). Outage = fail-open, never blocks.
REDIS_URL=redis://localhost:6379

# Response cache: identical non-streaming requests are served from Redis.
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Budget caps (per "team", from the x-slice-team header; default team "default").
BUDGET_ENABLED=true
# Per-team spend limit in USD. Override one team with BUDGET_LIMIT_<TEAM>, e.g.
# BUDGET_LIMIT_ACME=2.50 for team "acme".
BUDGET_LIMIT_USD=10.00
# Emit a budget-warning event when spend crosses this fraction of the cap.
BUDGET_WARN_RATIO=0.8

# --- Phase 6: cost-ranking-informed model choice within a tier ---
# CSV the Kedro pipeline writes. Loaded into memory at startup and refreshed on the
# interval below; the router never reads it per-request. Fail-open: if it's missing,
# empty, or unreadable, the router falls back to the configured tier model above.
RANKING_FILE=../pipeline/slice-pipeline/data/08_reporting/model_cost_ranking.csv
RANKING_RELOAD_MS=300000

# --- Phase 7: agent loop (circuit breaker) ---
# OPT-IN per request via the header `x-slice-agent: on`. Absent that header slice
# stays a transparent proxy, so these only take effect for agent-mode requests.
# Per-task budget CEILING in USD. The loop totals spend across its attempts and
# stops before the next attempt would cross this, returning the best answer so far.
AGENT_TASK_BUDGET_USD=0.50
# Cheap model used for the soft verifier ("does this fully answer the request?").
AGENT_VERIFIER_MODEL=claude-haiku-4-5-20251001
# The ladder reuses the tier env vars above (ROUTER_CHEAP_MODEL, ROUTER_STRONG_MODEL),
# ordered cheapest -> strongest by the Phase 6 cost ranking.

# --- Phase 8: multi-provider adapters (OpenAI) ---
# When the resolved model is an OpenAI model (gpt-*, o-*), slice translates the
# Anthropic-format request to OpenAI and back. OpenAI calls use THIS server key,
# never the client's key. Anthropic models are unaffected (default behavior).
OPENAI_API_KEY=sk-your-openai-key-here
# Optional override of the OpenAI base URL (e.g. for a proxy or Azure-compatible
# gateway). Defaults to the public API. The adapter appends /chat/completions.
OPENAI_BASE_URL=https://api.openai.com/v1
# Per-model OpenAI prices ship as safe defaults in src/pricing.ts; override the
# whole price table (all providers) as JSON via MODEL_PRICES if you need to.

# --- Phase 5: read-only stats API (/api/*) for the dashboard ---
# CORS origin allowed to call the /api endpoints. "*" is fine for local dev; in
# production set it to the dashboard's URL (e.g. https://dashboard.example.com).
DASHBOARD_ORIGIN=*
